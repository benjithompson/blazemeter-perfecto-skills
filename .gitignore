# macOS
.DS_Store

# Local agent / editor state
.scratch/
.claude/settings.local.json

# Secrets & env
.env
.env.*
!.env.example
# BlazeMeter API key files (BLAZEMETER_API_KEY may point at one) — never commit
api-key*.json
api-keys*.json
