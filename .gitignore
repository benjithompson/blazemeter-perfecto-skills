tests/live.env

# Dependencies / build (adjust once implementation stack is chosen)
node_modules/
dist/
build/
__pycache__/
*.pyc
.venv/

# Python test tooling
.pytest_cache/

# Generated reports (default output dir of the report engine)
blazemeter-reports/
