# Live integration test config — copy to `tests/live.env` (gitignored) and fill in,
# or set these as real environment variables (env always wins over the file).
#
# Run the live tests with:   pytest -m live
# Without these, `pytest -m live` simply SKIPS the live tests (never fails).

# --- Credentials (reuse the BlazeMeter MCP's own scheme) ---------------------
# Either set API_KEY_ID + API_KEY_SECRET, or point BLAZEMETER_API_KEY at a JSON
# key file {"id": "...", "secret": "..."} (the same file the MCP uses).
# Alternatively, drop a gitignored `api-key.json` at the repo root — it's picked up
# automatically, so you can leave this unset.
BLAZEMETER_API_KEY=/absolute/path/to/api-key.json

# --- Live targets (each test skips if its id is unset) -----------------------
# An execution / master id that produced artifacts (for the download test):
BZM_LIVE_EXECUTION_ID=
# A throwaway test id to upload an auth.json asset to (for the upload test):
BZM_LIVE_TEST_ID=
